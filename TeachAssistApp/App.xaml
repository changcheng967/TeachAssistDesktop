<Application x:Class="TeachAssistApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:TeachAssistApp">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="/Themes/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <local:StringToBoolConverter x:Key="StringToBoolConverter"/>
            <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <local:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
            <local:StringToBrushConverter x:Key="StringToBrushConverter"/>
            <local:MarkToColorConverter x:Key="MarkToColorConverter"/>
            <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <local:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibilityConverter"/>
            <local:PercentageConverter x:Key="PercentageConverter"/>
            <local:ImpactDeltaToColorConverter x:Key="ImpactDeltaToColorConverter"/>
            <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <local:IntZeroToBoolConverter x:Key="IntZeroToBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
