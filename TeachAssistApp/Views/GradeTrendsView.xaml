<Window x:Class="TeachAssistApp.Views.GradeTrendsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grade Trends - TeachAssist"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#FF0D1117">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#FF161B22"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF8B949E"/>
        <SolidColorBrush x:Key="Accent" Color="#FF58A6FF"/>
        <SolidColorBrush x:Key="Success" Color="#FF238636"/>
        <SolidColorBrush x:Key="Warning" Color="#FFD29922"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Padding="30">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <TextBlock Text="📈 Grade Trends"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"/>
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        Foreground="{StaticResource TextSecondary}"
                        BorderThickness="0"
                        FontSize="16"
                        Padding="8"
                        Cursor="Hand"
                        Command="{Binding CloseCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#FFF85149"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Overall Stats -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Overall Average"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}">
                            <Run Text="{Binding OverallAverage, StringFormat=\{0:F1\}%}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Highest Mark"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Success}">
                            <Run Text="{Binding HighestMark, StringFormat=\{0:F1\}%}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Lowest Mark"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Warning}">
                            <Run Text="{Binding LowestMark, StringFormat=\{0:F1\}%}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Course Trends -->
            <TextBlock Text="Course Performance Trends"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,12"/>

            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding CourseTrends}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Course Name -->
                                        <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Code}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Progress Bar -->
                                        <Border Grid.Column="1"
                                                Height="24"
                                                CornerRadius="4"
                                                Background="#FF21262D"
                                                Margin="12,0">
                                            <Border HorizontalAlignment="Left"
                                                    CornerRadius="4"
                                                    Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                        <Binding Path="Mark" Mode="OneWay"/>
                                                        <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Border}" Path="ActualWidth" Mode="OneWay"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Border>

                                        <!-- Mark -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Mark, StringFormat=\{0:F0\}%}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Insights -->
            <Border Background="#FF21262D"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="💡 Insights"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding Insights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding .}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,6"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Close Button -->
            <Button Content="Close"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource ModernButton}"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0"
                    Background="#FF30363D"/>
        </StackPanel>
    </Border>
</Window>
