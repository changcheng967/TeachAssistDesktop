<Window x:Class="TeachAssistApp.Views.GradeTrendsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grade Trends - TeachAssist"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#FF0D1117"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="#FF30363D"
        Loaded="Window_Loaded">
    <Window.Effect>
        <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="0" Opacity="0.5"/>
    </Window.Effect>

    <Border CornerRadius="12" Background="#FF0D1117">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    Padding="24,16,24,16"
                    BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32"
                                CornerRadius="8"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF58A6FF" Offset="0"/>
                                    <GradientStop Color="#FF2188FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF58A6FF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <TextBlock Text="&#xE7E7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Grade Trends"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI Variable Display"/>
                    </StackPanel>
                    <Button Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SubWindowCloseButton}"
                            Command="{Binding CloseCommand}"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,20,28,28">
                <StackPanel>
                    <!-- Overall Stats -->
                    <Border Background="{StaticResource CardBackground}"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,20"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Overall Average"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Accent}">
                                    <Run Text="{Binding OverallAverage, StringFormat=\{0:F1\}%}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Highest Mark"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Success}">
                                    <Run Text="{Binding HighestMark, StringFormat=\{0:F1\}%}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Lowest Mark"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Warning}">
                                    <Run Text="{Binding LowestMark, StringFormat=\{0:F1\}%}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Course Trends -->
                    <TextBlock Text="Course Performance Trends"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,12"/>

                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CourseTrends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBackground}"
                                            CornerRadius="8"
                                            Padding="16"
                                            Margin="0,0,0,10"
                                            BorderBrush="{StaticResource CardBorder}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Code}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Height="24"
                                                    CornerRadius="4"
                                                    Background="{StaticResource SubtleBackground}"
                                                    Margin="12,0">
                                                <Border HorizontalAlignment="Left"
                                                        CornerRadius="4"
                                                        Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                            <Binding Path="Mark" Mode="OneWay"/>
                                                            <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Border}" Path="ActualWidth" Mode="OneWay"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Border>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Mark, StringFormat=\{0:F0\}%}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Insights -->
                    <Border Background="{StaticResource SubtleBackground}"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,20,0,20">
                        <StackPanel>
                            <TextBlock Text="&#xE946;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Insights"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding Insights}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding .}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,0,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Close Button -->
                    <Button Content="Close"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource ModernButton}"
                            HorizontalAlignment="Right"
                            Background="{StaticResource CardBorder}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
