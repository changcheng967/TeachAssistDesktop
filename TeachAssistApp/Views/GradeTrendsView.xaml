<ui:FluentWindow x:Class="TeachAssistApp.Views.GradeTrendsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Grade Trends - TeachAssist"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="Grade Trends" />

        <!-- Gradient accent line under title -->
        <Border Height="3" VerticalAlignment="Top" Margin="0,32,0,0"
                Background="{StaticResource AccentGradientHorizontal}"/>

        <Grid Margin="0,35,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,20,32,60">
                <StackPanel>
                    <!-- Overall Stats -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <ui:Card Margin="0,0,12,0">
                            <StackPanel Margin="16,12">
                                <TextBlock Text="Overall Average" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding OverallAverage, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </ui:Card>
                        <ui:Card Margin="0,0,12,0">
                            <StackPanel Margin="16,12">
                                <TextBlock Text="Highest Mark" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding HighestMark, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                        </ui:Card>
                        <ui:Card>
                            <StackPanel Margin="16,12">
                                <TextBlock Text="Lowest Mark" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding LowestMark, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>

                    <!-- Course Trends -->
                    <TextBlock Text="Course Performance Trends"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CourseTrends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" CornerRadius="8"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Grade color accent bar -->
                                            <Border Grid.Column="0" CornerRadius="8,0,0,8"
                                                    Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>

                                            <StackPanel Grid.Column="1" Margin="12,10,0,10" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Code}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <ProgressBar Grid.Column="2" Height="8" Value="{Binding Mark}" Maximum="100"
                                                         Margin="12,0" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Mark, StringFormat={}{0:F0}%}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,12,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Insights -->
                    <ui:Card Margin="0,20,0,20">
                        <StackPanel Margin="12,10">
                            <TextBlock Text="Insights" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Insights}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding .}" FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>

            <!-- Fixed close button at bottom -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Background="{DynamicResource ApplicationPageBackgroundThemeBrush}" Padding="0,12,0,12">
                <ui:Button Content="Close" Command="{Binding CloseCommand}" Appearance="Secondary"
                           HorizontalAlignment="Right" Margin="0,0,32,0"/>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
