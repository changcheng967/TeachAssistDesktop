<ui:FluentWindow x:Class="TeachAssistApp.Views.GradeTrendsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:helpers="clr-namespace:TeachAssistApp.Helpers"
        Title="Grade Trends - TeachAssist"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="Grade Trends" />

        <!-- Gradient accent line -->
        <Border Height="3" VerticalAlignment="Top" Margin="0,32,0,0"
                Background="{StaticResource AccentGradientHorizontal}"/>

        <Grid Margin="0,35,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                          helpers:SmoothScrollBehavior.IsEnabled="True" Padding="32,24,32,60">
                <StackPanel>
                    <!-- Stats row -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Average — grade-colored -->
                        <Border Grid.Column="0" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                        Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>
                                <StackPanel Grid.Column="1" Margin="14,12">
                                    <TextBlock Text="Overall Average" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding OverallAverage, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="Bold"
                                               Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Highest -->
                        <Border Grid.Column="2" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10,0,0,10" Background="{StaticResource SuccessGradient}"/>
                                <StackPanel Grid.Column="1" Margin="14,12">
                                    <TextBlock Text="Highest Mark" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding HighestMark, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Lowest -->
                        <Border Grid.Column="4" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10,0,0,10" Background="{StaticResource WarmGradient}"/>
                                <StackPanel Grid.Column="1" Margin="14,12">
                                    <TextBlock Text="Lowest Mark" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding LowestMark, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Course Performance -->
                    <TextBlock Text="COURSE PERFORMANCE" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>

                    <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                        <ItemsControl ItemsSource="{Binding CourseTrends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="10"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            Effect="{StaticResource CardDefaultShadow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="65"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                                    Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>

                                            <StackPanel Grid.Column="1" Margin="14,12,0,12" VerticalAlignment="Center">

                                                <TextBlock Text="{Binding Code}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Name}" FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <ProgressBar Grid.Column="2" Height="4" Value="{Binding Mark, Mode=OneWay}" Maximum="100"
                                                         Margin="14,0" VerticalAlignment="Center"
                                                         Style="{StaticResource ThinProgressBar}"/>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Mark, StringFormat={}{0:F0}%}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,14,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Insights -->
                    <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            Effect="{StaticResource CardDefaultShadow}" Margin="0,20,0,20" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Insights" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Insights}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding .}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Fixed close button -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
                    CornerRadius="10,10,0,0" Padding="20,12,32,12"
                    Effect="{StaticResource CardDefaultShadow}">
                <ui:Button Content="Close" Command="{Binding CloseCommand}" Appearance="Secondary"
                           HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
