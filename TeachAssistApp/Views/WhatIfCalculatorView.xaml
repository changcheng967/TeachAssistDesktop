<ui:FluentWindow x:Class="TeachAssistApp.Views.WhatIfCalculatorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="What-If Calculator - TeachAssist"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="What-If Calculator" />

        <ScrollViewer Margin="0,32,0,0" VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel>
                <!-- Current GPA Display -->
                <ui:Card Margin="0,0,0,20">
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Current Average" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CurrentGpa, StringFormat={}{0:F1}%}" FontSize="36" FontWeight="Bold"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,8,0,0">
                            <Run Text="Across "/><Run Text="{Binding CourseCount}" FontWeight="SemiBold"/><Run Text=" courses"/>
                        </TextBlock>
                    </StackPanel>
                </ui:Card>

                <!-- Add Hypothetical Assignment -->
                <TextBlock Text="Add Hypothetical Assignment" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <ui:Card Margin="0,0,0,20">
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Assignment Name" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                        <ui:TextBox Text="{Binding NewAssignmentName, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Enter name" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Mark (%)" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding NewAssignmentMark, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="0-100"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Weight (%)" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding NewAssignmentWeight, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="0-100"/>
                            </StackPanel>
                        </Grid>

                        <ui:Button Content="Add Assignment" Command="{Binding AddAssignmentCommand}"
                                   Appearance="Primary" HorizontalAlignment="Stretch"
                                   Style="{StaticResource AnimatedButton}" RenderTransformOrigin="0.5,0.5"/>
                    </StackPanel>
                </ui:Card>

                <!-- Projected Results -->
                <ui:Card Margin="0,0,0,12"
                         Visibility="{Binding HasHypotheticalAssignments, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Projected Average" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ProjectedGpa, StringFormat={}{0:F1}%}" FontSize="32" FontWeight="Bold"/>
                        <TextBlock FontSize="12" Margin="0,4,0,0">
                            <Run Text="Difference: "/>
                            <Run Text="{Binding GpaDifference, StringFormat={}{0:+0.0;-0.0}%}"/>
                        </TextBlock>
                    </StackPanel>
                </ui:Card>

                <!-- Hypothetical Assignments List -->
                <ui:Card Visibility="{Binding HasHypotheticalAssignments, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Hypothetical Assignments" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding HypotheticalAssignments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="14"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" Text="{Binding Mark, StringFormat={}{0:F0}%}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <ui:Button Grid.Column="2" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   Command="{Binding RemoveCommand}" CommandParameter="{Binding}"
                                                   Appearance="Secondary" Padding="6" FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
