<ui:FluentWindow x:Class="TeachAssistApp.Views.WhatIfCalculatorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="What-If Calculator - TeachAssist"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="What-If Calculator" />

        <!-- Gradient accent line -->
        <Border Height="3" VerticalAlignment="Top" Margin="0,32,0,0"
                Background="{StaticResource AccentGradientHorizontal}"/>

        <ScrollViewer Margin="0,35,0,0" VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel>
                <!-- Current Average — hero card -->
                <Border Margin="0,0,0,20" CornerRadius="14"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        Effect="{StaticResource CardElevatedShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="14,0,0,14"
                                Background="{StaticResource AccentGradient}"/>

                        <StackPanel Grid.Column="1" Margin="24,20">
                            <TextBlock Text="Current Average" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CurrentGpa, StringFormat={}{0:F1}%}" FontSize="40" FontWeight="Bold"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,8,0,0">
                                <Run Text="Across "/><Run Text="{Binding CourseCount}" FontWeight="SemiBold"/><Run Text=" courses"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Add Hypothetical Assignment -->
                <TextBlock Text="Add Hypothetical Assignment" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <ui:Card Margin="0,0,0,20">
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Assignment Name" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,6"/>
                        <ui:TextBox Text="{Binding NewAssignmentName, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Enter name" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Mark (%)" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding NewAssignmentMark, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="0-100"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Weight (%)" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding NewAssignmentWeight, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="0-100"/>
                            </StackPanel>
                        </Grid>

                        <ui:Button Content="Add Assignment" Command="{Binding AddAssignmentCommand}"
                                   Appearance="Primary" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ui:Card>

                <!-- Projected Results — with color-coded accent -->
                <Border Margin="0,0,0,12" CornerRadius="12"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        Effect="{StaticResource CardDefaultShadow}"
                        Visibility="{Binding HasHypotheticalAssignments, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="12,0,0,12"
                                Background="{Binding GpaDifference, Converter={StaticResource ImpactDeltaToColorConverter}}" Opacity="0.7"/>

                        <StackPanel Grid.Column="1" Margin="20,16">
                            <TextBlock Text="Projected Average" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ProjectedGpa, StringFormat={}{0:F1}%}" FontSize="32" FontWeight="Bold"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0"
                                       Foreground="{Binding GpaDifference, Converter={StaticResource ImpactDeltaToColorConverter}}">
                                <Run Text="{Binding GpaDifference, StringFormat={}{0:+0.0;-0.0}%}"/>
                                <Run Text=" difference" FontSize="11" FontWeight="Normal"
                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hypothetical Assignments List -->
                <ui:Card Visibility="{Binding HasHypotheticalAssignments, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Hypothetical Assignments" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding HypotheticalAssignments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" Text="{Binding Mark, StringFormat={}{0:F0}%}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <ui:Button Grid.Column="2" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   Command="{Binding RemoveCommand}" CommandParameter="{Binding}"
                                                   Appearance="Secondary" Padding="6" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
