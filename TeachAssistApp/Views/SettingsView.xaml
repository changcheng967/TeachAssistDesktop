<Page x:Class="TeachAssistApp.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32" Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">

            <!-- Header with gradient accent -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Settings"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,4"/>
                    <Border Width="60" Height="3" CornerRadius="1.5"
                            Background="{StaticResource AccentGradientHorizontal}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>

            <!-- Appearance -->
            <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
            <ui:Card Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dark Mode" FontSize="14" VerticalAlignment="Center"/>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDarkMode}" VerticalAlignment="Center"/>
                    </Grid>
                    <Separator Margin="16,0"/>
                    <Grid Margin="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Auto-refresh every"/><Run FontWeight="SemiBold" Text="{Binding AutoRefreshInterval}"/><Run Text=" min"/>
                        </TextBlock>
                        <ComboBox Grid.Column="1" SelectedIndex="{Binding AutoRefreshIndex}" Width="100" FontSize="13">
                            <ComboBoxItem Content="Off"/>
                            <ComboBoxItem Content="5 min"/>
                            <ComboBoxItem Content="10 min"/>
                            <ComboBoxItem Content="15 min"/>
                            <ComboBoxItem Content="30 min"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Tools -->
            <TextBlock Text="TOOLS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
            <ui:Card Margin="0,0,0,24">
                <Grid Margin="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ui:CardAction Grid.Row="0" Grid.Column="0" Command="{Binding ViewTrendsCommand}"
                                   Icon="{ui:SymbolIcon ArrowTrendingLines24}" Content="Grade Trends"/>
                    <ui:CardAction Grid.Row="0" Grid.Column="2" Command="{Binding GradeGoalsCommand}"
                                   Icon="{ui:SymbolIcon ChartMultiple24}" Content="Grade Goals"/>
                    <ui:CardAction Grid.Row="2" Grid.Column="0" Command="{Binding WhatIfCalculatorCommand}"
                                   Icon="{ui:SymbolIcon Calculator24}" Content="What-If Calculator"/>
                    <ui:CardAction Grid.Row="2" Grid.Column="2" Command="{Binding CheckForUpdatesCommand}"
                                   Icon="{ui:SymbolIcon ArrowSyncCheckmark24}" Content="Check for Updates"/>
                    <ui:CardAction Grid.Row="4" Grid.Column="0" Command="{Binding ExportToCsvCommand}"
                                   Icon="{ui:SymbolIcon ArrowExportLtr24}" Content="Export CSV"/>
                    <ui:CardAction Grid.Row="4" Grid.Column="2" Command="{Binding ExportToPdfCommand}"
                                   Icon="{ui:SymbolIcon Document24}" Content="Export Report (HTML)"/>
                </Grid>
            </ui:Card>

            <!-- Account -->
            <TextBlock Text="ACCOUNT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
            <ui:Card Margin="0,0,0,20">
                <StackPanel>
                    <Border Margin="16,14,16,0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="6" Padding="12">
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Logged in as "/><Run Text="{Binding Username}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                    <Grid Margin="16,14">
                        <ui:Button Command="{Binding RefreshGradesCommand}" Appearance="Primary"
                                   Icon="{ui:SymbolIcon ArrowSyncCheckmark24}" Content="Refresh Grades"/>
                        <ui:Button Command="{Binding LogoutCommand}" Appearance="Danger"
                                   Icon="{ui:SymbolIcon ArrowExportRtl24}" Content="Logout"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Data -->
            <TextBlock Text="DATA" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
            <ui:Card Margin="0,0,0,20">
                <ui:CardAction Command="{Binding ClearCacheCommand}"
                               Icon="{ui:SymbolIcon Delete24}" Content="Clear Cached Data"
                               Margin="8"/>
            </ui:Card>

            <!-- Keyboard Shortcuts -->
            <TextBlock Text="KEYBOARD SHORTCUTS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
            <ui:Card Margin="0,0,0,20">
                <Grid Margin="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Refresh</TextBlock>
                    <ui:Badge Grid.Row="0" Grid.Column="1" Content="F5" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Settings</TextBlock>
                    <ui:Badge Grid.Row="1" Grid.Column="1" Content="Ctrl + ," HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Export</TextBlock>
                    <ui:Badge Grid.Row="2" Grid.Column="1" Content="Ctrl + E" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Go Back</TextBlock>
                    <ui:Badge Grid.Row="3" Grid.Column="1" Content="Esc" HorizontalAlignment="Right"/>
                </Grid>
            </ui:Card>

            <!-- About -->
            <TextBlock Text="ABOUT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
            <ui:Card Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="16,14">
                    <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#6366F1" BlurRadius="16" ShadowDepth="0" Opacity="0.25" Direction="0"/>
                        </Border.Effect>
                        <Image Source="/logo.png" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="15" FontWeight="SemiBold">TeachAssist Desktop</TextBlock>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Version "/><Run Text="{Binding AppVersion}" FontWeight="SemiBold"/><Run Text=" by changcheng967"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="{Binding UpdateStatus}" Visibility="{Binding UpdateStatus, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>

    <!-- Loading Overlay -->
    <Grid Background="{DynamicResource OverlayBrush}"
          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
        <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>

    <!-- Success Message -->
    <ui:InfoBar Message="{Binding SuccessMessage}"
                Severity="Success"
                IsOpen="{Binding SuccessMessage, Converter={StaticResource StringToBoolConverter}}"
                Margin="32,48,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="500"/>

    <!-- Error Message -->
    <ui:InfoBar Title="Error"
                Message="{Binding ErrorMessage}"
                Severity="Error"
                IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                Margin="32,48,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="500"/>
    </Grid>
</Page>
