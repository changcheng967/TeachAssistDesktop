<Page x:Class="TeachAssistApp.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Background="#FF0D1117"
      Title="Settings - TeachAssist">

    <Page.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#FF161B22"/>
        <SolidColorBrush x:Key="CardBorder" Color="#FF30363D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF8B949E"/>
        <SolidColorBrush x:Key="Accent" Color="#FF58A6FF"/>
        <SolidColorBrush x:Key="Success" Color="#FF238636"/>
        <SolidColorBrush x:Key="Warning" Color="#FFD29922"/>
        <SolidColorBrush x:Key="Danger" Color="#FFF85149"/>

        <Style x:Key="CompactCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="CompactButton" TargetType="Button">
            <Setter Property="Background" Value="#FF21262D"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF30363D"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF30363D"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource CompactButton}">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2EA043"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource CompactButton}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFDA6F6E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact Header -->
        <Border Grid.Row="0"
                Background="#FF010409"
                BorderBrush="#FF30363D"
                BorderThickness="0,0,0,1"
                Padding="20,12,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← Back"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource CompactButton}"
                        Padding="8,4"
                        FontSize="12"
                        Margin="0,0,12,0"/>

                <TextBlock Grid.Column="1"
                           Text="Settings"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Compact Settings Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,16,20,20">
            <StackPanel MaxWidth="700">
                <!-- Appearance Section -->
                <TextBlock Text="APPEARANCE"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,8"/>

                <Border Style="{StaticResource CompactCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Dark Mode"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsDarkMode}"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="#FF0D1117"
                                Padding="12"
                                CornerRadius="6"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}">
                                    <Run Text="Auto-refresh grades every"/>
                                    <Run Text="{Binding AutoRefreshInterval}" FontWeight="SemiBold"/>
                                    <Run Text="minutes"/>
                                </TextBlock>

                                <ComboBox Grid.Column="1"
                                          SelectedIndex="{Binding AutoRefreshIndex}"
                                          Width="80"
                                          FontSize="12">
                                    <ComboBoxItem Content="Off"/>
                                    <ComboBoxItem Content="5 min"/>
                                    <ComboBoxItem Content="10 min"/>
                                    <ComboBoxItem Content="15 min"/>
                                    <ComboBoxItem Content="30 min"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <CheckBox Content="Enable desktop notifications for grade changes"
                                  IsChecked="{Binding EnableNotifications}"
                                  FontSize="13"
                                  Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- Data & Export Section -->
                <TextBlock Text="DATA &amp; EXPORT"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,8"/>

                <Border Style="{StaticResource CompactCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Button Content="📊 Export All Grades to CSV"
                                    Command="{Binding ExportToCsvCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"/>

                            <Button Content="📄 Export to PDF"
                                    Command="{Binding ExportToPdfCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Right"
                                    Grid.Column="1"/>
                        </Grid>

                        <Button Content="📈 View Grade Trends"
                                Command="{Binding ViewTrendsCommand}"
                                Style="{StaticResource CompactButton}"
                                Margin="0,0,0,8"/>

                        <Button Content="🎯 Grade Goals"
                                Command="{Binding GradeGoalsCommand}"
                                Style="{StaticResource CompactButton}"
                                Margin="0,0,0,8"/>

                        <Button Content="🧮 What-If GPA Calculator"
                                Command="{Binding WhatIfCalculatorCommand}"
                                Style="{StaticResource CompactButton}"
                                Margin="0,0,0,8"/>

                        <Button Content="🔔 Check for Grade Updates"
                                Command="{Binding CheckUpdatesCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,8"/>

                        <Grid>
                            <Button Content="🗑️ Clear Cached Data"
                                    Command="{Binding ClearCacheCommand}"
                                    Style="{StaticResource CompactButton}"
                                    HorizontalAlignment="Left"/>

                            <TextBlock Grid.Column="1"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="300"
                                       TextAlignment="Right">
                                Removes stored credentials and cached data
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Account Section -->
                <TextBlock Text="ACCOUNT"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,8"/>

                <Border Style="{StaticResource CompactCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <Border Background="#FF0D1117"
                                Padding="12"
                                CornerRadius="6"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                    <Run Text="Logged in as:"/>
                                </TextBlock>
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,2,0,0">
                                    <Run Text="{Binding Username}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Button Content="🔄 Refresh Grades"
                                    Command="{Binding RefreshGradesCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"/>

                            <Button Content="🚪 Logout"
                                    Command="{Binding LogoutCommand}"
                                    Style="{StaticResource DangerButton}"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Shortcuts Section -->
                <TextBlock Text="KEYBOARD SHORTCUTS"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,8"/>

                <Border Style="{StaticResource CompactCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,6">
                            <Run Text="Refresh"/>
                        </TextBlock>
                        <Border Grid.Row="0" Grid.Column="1"
                                Background="#FF21262D"
                                Padding="6,3"
                                CornerRadius="4"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">F5</TextBlock>
                        </Border>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,6">
                            <Run Text="Settings"/>
                        </TextBlock>
                        <Border Grid.Row="1" Grid.Column="1"
                                Background="#FF21262D"
                                Padding="6,3"
                                CornerRadius="4"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">Ctrl + ,</TextBlock>
                        </Border>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,6">
                            <Run Text="Export"/>
                        </TextBlock>
                        <Border Grid.Row="2" Grid.Column="1"
                                Background="#FF21262D"
                                Padding="6,3"
                                CornerRadius="4"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">Ctrl + E</TextBlock>
                        </Border>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimary}">
                            <Run Text="Go Back"/>
                        </TextBlock>
                        <Border Grid.Row="3" Grid.Column="1"
                                Background="#FF21262D"
                                Padding="6,3"
                                CornerRadius="4"
                                HorizontalAlignment="Right">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">Esc</TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!-- About Section -->
                <TextBlock Text="ABOUT"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,8"/>

                <Border Style="{StaticResource CompactCard}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="32" Height="32"
                                     Fill="{StaticResource Success}"
                                     Margin="0,0,12,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF238636" BlurRadius="6" Opacity="0.4"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <StackPanel Grid.Column="1">
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}">
                                    <Run Text="TeachAssist Desktop"/>
                                </TextBlock>
                                <TextBlock FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,2,0,0">
                                    <Run Text="Version "/>
                                    <Run Text="{Binding AppVersion}" FontWeight="SemiBold"/>
                                    <Run Text=" • "/>
                                    <Run Text="by " FontWeight="Normal"/>
                                    <Run Text="changcheng967" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="16">
                            A premium Windows desktop application for YRDSB students to check their TeachAssist grades with advanced analytics, grade goals, and what-if calculations.
                        </TextBlock>

                        <Border Background="#FF0D1117"
                                Padding="10"
                                CornerRadius="6"
                                Margin="0,12,0,0">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                                <Run Text="💡 Tip: Right-click courses for quick actions"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1"
              Background="#DD0D1117"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="40" Height="40"
                        BorderThickness="2"
                        BorderBrush="{StaticResource Accent}"
                        CornerRadius="20"
                        Margin="0,0,0,12">
                    <Border.RenderTransform>
                        <RotateTransform Angle="0"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                   From="0" To="360" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
                <TextBlock Text="Processing..."
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Status Message -->
        <Border Grid.Row="1"
                Background="{StaticResource Success}"
                CornerRadius="8"
                Padding="16,12"
                Margin="20,60,20,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Medium"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Error Message -->
        <Border Grid.Row="1"
                Background="{StaticResource Danger}"
                CornerRadius="8"
                Padding="16,12"
                Margin="20,60,20,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Medium"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
