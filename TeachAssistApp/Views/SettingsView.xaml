<Page x:Class="TeachAssistApp.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32" Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">

            <!-- Header -->
            <TextBlock Text="Settings"
                       FontSize="26" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,6"/>
            <Border Width="50" Height="3" CornerRadius="1.5"
                    Background="{StaticResource AccentGradientHorizontal}"
                    HorizontalAlignment="Left" Margin="0,0,0,28"/>

            <!-- APPEARANCE -->
            <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>
            <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Effect="{StaticResource CardDefaultShadow}" Margin="0,0,0,28">
                <StackPanel>
                    <Grid Margin="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dark Mode" FontSize="14" VerticalAlignment="Center"/>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDarkMode}" VerticalAlignment="Center"/>
                    </Grid>
                    <Separator Margin="16,0"/>
                    <Grid Margin="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Auto-refresh every"/><Run FontWeight="SemiBold" Text="{Binding AutoRefreshInterval}"/><Run Text=" min"/>
                        </TextBlock>
                        <ComboBox Grid.Column="1" SelectedIndex="{Binding AutoRefreshIndex}" Width="100" FontSize="13">
                            <ComboBoxItem Content="Off"/>
                            <ComboBoxItem Content="5 min"/>
                            <ComboBoxItem Content="10 min"/>
                            <ComboBoxItem Content="15 min"/>
                            <ComboBoxItem Content="30 min"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- TOOLS — custom grid of clickable tiles -->
            <TextBlock Text="TOOLS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tool tiles with hover animation -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource InteractiveTile}" Padding="14,12"
                        MouseLeftButtonDown="ToolTrends_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowTrendingLines24" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Grade Trends" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource InteractiveTile}" Padding="14,12"
                        MouseLeftButtonDown="ToolGoals_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ChartMultiple24" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Grade Goals" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource InteractiveTile}" Padding="14,12"
                        MouseLeftButtonDown="ToolWhatIf_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Calculator24" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="What-If Calc" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource InteractiveTile}" Padding="14,12"
                        MouseLeftButtonDown="ToolUpdate_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSyncCheckmark24" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Check Updates" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource InteractiveTile}" Padding="14,12"
                        MouseLeftButtonDown="ToolCsv_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowExportLtr24" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Export CSV" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource InteractiveTile}" Padding="14,12"
                        MouseLeftButtonDown="ToolPdf_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Export HTML" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ACCOUNT -->
            <TextBlock Text="ACCOUNT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>
            <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Effect="{StaticResource CardDefaultShadow}" Margin="0,0,0,28">
                <StackPanel>
                    <Border Margin="16,14,16,0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="6" Padding="12">
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Logged in as "/><Run Text="{Binding Username}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                    <Grid Margin="16,14">
                        <ui:Button Command="{Binding RefreshGradesCommand}" Appearance="Primary"
                                   Icon="{ui:SymbolIcon ArrowSyncCheckmark24}" Content="Refresh Grades"/>
                        <ui:Button Command="{Binding LogoutCommand}" Appearance="Danger"
                                   Icon="{ui:SymbolIcon ArrowExportRtl24}" Content="Logout"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- DATA -->
            <TextBlock Text="DATA" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>
            <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Effect="{StaticResource CardDefaultShadow}" Padding="14,12" Margin="0,0,0,28" Cursor="Hand"
                    MouseLeftButtonDown="DataClear_Click">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Delete24" FontSize="16" Margin="0,0,10,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Clear Cached Data" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- KEYBOARD SHORTCUTS -->
            <TextBlock Text="KEYBOARD SHORTCUTS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>
            <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Effect="{StaticResource CardDefaultShadow}" Margin="0,0,0,28">
                <Grid Margin="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Refresh</TextBlock>
                    <Border Grid.Row="0" Grid.Column="1" CornerRadius="4" HorizontalAlignment="Right"
                            Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8,3">
                        <TextBlock Text="F5" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Settings</TextBlock>
                    <Border Grid.Row="1" Grid.Column="1" CornerRadius="4" HorizontalAlignment="Right"
                            Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8,3">
                        <TextBlock Text="Ctrl + ," FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>

                    <TextBlock Grid.Row="2" Grid.Column="0" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Export</TextBlock>
                    <Border Grid.Row="2" Grid.Column="1" CornerRadius="4" HorizontalAlignment="Right"
                            Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8,3">
                        <TextBlock Text="Ctrl + E" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>

                    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">Go Back</TextBlock>
                    <Border Grid.Row="3" Grid.Column="1" CornerRadius="4" HorizontalAlignment="Right"
                            Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8,3">
                        <TextBlock Text="Esc" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ABOUT -->
            <TextBlock Text="ABOUT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>
            <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Effect="{StaticResource CardDefaultShadow}" Margin="0,0,0,20">
                <Grid Margin="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#6366F1" BlurRadius="14" ShadowDepth="0" Opacity="0.2" Direction="0"/>
                        </Border.Effect>
                        <Image Source="/logo.png" Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock FontSize="15" FontWeight="SemiBold">TeachAssist Desktop</TextBlock>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Version "/><Run Text="{Binding AppVersion}" FontWeight="SemiBold"/><Run Text=" by changcheng967"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="{Binding UpdateStatus}" Visibility="{Binding UpdateStatus, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>

    <!-- Loading Overlay -->
    <Grid Background="{DynamicResource OverlayBrush}"
          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
        <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>

    <!-- Success Message -->
    <ui:InfoBar Message="{Binding SuccessMessage}"
                Severity="Success"
                IsOpen="{Binding SuccessMessage, Converter={StaticResource StringToBoolConverter}}"
                Margin="32,48,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="500"/>

    <!-- Error Message -->
    <ui:InfoBar Title="Error"
                Message="{Binding ErrorMessage}"
                Severity="Error"
                IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                Margin="32,48,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="500"/>
    </Grid>
</Page>
