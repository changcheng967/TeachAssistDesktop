<Page x:Class="TeachAssistApp.Views.CourseDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="900">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32" Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">

            <!-- Header -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" Command="{Binding GoBackCommand}" Appearance="Secondary"
                           Icon="{ui:SymbolIcon ArrowLeft24}" ToolTip="Back" Margin="0,0,14,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCourse.Name}"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding SelectedCourse.Code}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding SelectedCourse.Room, StringFormat='Room {0}'}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding SelectedCourse.Block, StringFormat='Block {0}'}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Grade badge with soft glow -->
                <Border Grid.Column="2"
                        CornerRadius="12" Padding="20,10"
                        Background="{Binding SelectedCourse.GradeColor, Converter={StaticResource StringToBrushConverter}}"
                        Visibility="{Binding SelectedCourse, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.Effect>
                        <DropShadowEffect Color="#6366F1" BlurRadius="12" ShadowDepth="0" Opacity="0.15" Direction="0"/>
                    </Border.Effect>
                    <TextBlock Text="{Binding SelectedCourse.DisplayMark}" FontSize="22" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Grade Analytics Section -->
            <ui:CardExpander Header="Grade Analytics"
                            IsExpanded="True"
                            Icon="{ui:SymbolIcon ChartMultiple24}"
                            Visibility="{Binding HasGradeTimeline, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,12">
                <StackPanel Margin="0,8">
                    <!-- Bento-style stat cards -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Current grade — hero card with gradient accent -->
                        <Border Grid.Column="0" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                        Background="{StaticResource AccentGradient}"/>
                                <StackPanel Grid.Column="1" Margin="16,12">
                                    <TextBlock Text="Current" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Text="{Binding CurrentGrade, StringFormat={}{0:F1}%}" FontSize="26" FontWeight="Bold"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Change -->
                        <Border Grid.Column="2" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Change" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{Binding GradeChangeDisplay}" FontSize="20" FontWeight="Bold"
                                           Foreground="{Binding GradeChangeTotal, Converter={StaticResource ImpactDeltaToColorConverter}}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- High Impact -->
                        <Border Grid.Column="4" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="High Impact" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,4,0,0">
                                    <Run Text="{Binding HighImpactCount}"/>
                                    <Run Text=" tasks" FontSize="11"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Best -->
                        <Border Grid.Column="6" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Best Impact" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding BestAssignmentName}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxHeight="18"/>
                                <TextBlock Text="{Binding BestAssignmentImpact, StringFormat={}{0:+0.0;-0.0;0.0}%}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Chart -->
                    <ContentControl x:Name="ChartHost" Height="250" Margin="0,0,0,8"/>
                </StackPanel>
            </ui:CardExpander>

            <!-- Category Performance (standard courses) -->
            <ui:CardExpander Header="Category Performance"
                            IsExpanded="True"
                            Icon="{ui:SymbolIcon DataBarVertical24}"
                            Visibility="{Binding IsOEFormat, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                            Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding CategoryPerformance}" Margin="0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                <!-- Gradient-filled rounded progress bar -->
                                <Border Grid.Column="1" Height="7" CornerRadius="3.5" Margin="12,0"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        VerticalAlignment="Center">
                                    <Border CornerRadius="3.5" HorizontalAlignment="Left"
                                            Background="{StaticResource AccentGradient}">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                <Binding Path="Percentage"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding Percentage, StringFormat={}{0:F1}%}" FontSize="14"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ui:CardExpander>

            <!-- Expectation Performance (OE courses) -->
            <ui:CardExpander Header="Expectation Performance"
                            IsExpanded="True"
                            Icon="{ui:SymbolIcon DataBarVertical24}"
                            Visibility="{Binding IsOEFormat, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding ExpectationPerformance}" Margin="0,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,8,8" Padding="12,10" MinWidth="155">
                                <StackPanel>
                                    <ui:Badge Content="{Binding Code}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%}" FontSize="20" FontWeight="Bold"
                                               Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}" Margin="0,0,0,6"/>
                                    <ProgressBar Height="4" Value="{Binding Percentage, Mode=OneWay}" Maximum="100"
                                                 Style="{StaticResource ThinProgressBar}"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,6,0,0">
                                        <Run Text="{Binding AssignmentCount}"/><Run Text=" assessments"/>
                                    </TextBlock>
                                </StackPanel>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ui:CardExpander>

            <!-- Assignments -->
            <ui:CardExpander Header="Assignments"
                            IsExpanded="True"
                            Icon="{ui:SymbolIcon Document24}"
                            Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding AssignmentGroups}" Margin="0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,8">
                                <StackPanel Margin="12,8">
                                    <!-- Group header -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Margin="0,0,6,0"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4" Padding="8,3"
                                                Visibility="{Binding Impact, Converter={StaticResource NullToVisibilityConverter}}"
                                                ToolTip="Weighted contribution to final grade">
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Worth {0}">
                                                        <Binding Path="Impact.DisplayContribution"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                        <Border Grid.Column="2"
                                                Background="{Binding Impact.ImpactColor, Converter={StaticResource StringToBrushConverter}}"
                                                CornerRadius="4" Padding="8,3"
                                                Visibility="{Binding Impact, Converter={StaticResource NullToVisibilityConverter}}"
                                                ToolTip="Grade change after this assignment">
                                            <TextBlock Text="{Binding Impact.DisplayImpact}" FontSize="11" FontWeight="SemiBold" Foreground="White"
                                                       ToolTip="Actual impact on your final grade"/>
                                        </Border>
                                    </Grid>

                                    <!-- Individual assignments -->
                                    <ItemsControl ItemsSource="{Binding Assignments}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="8" Padding="12,10" Margin="0,0,8,8" MinWidth="120"
                                                        Effect="{StaticResource CardDefaultShadow}"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                    To="1.02" Duration="0:0:0.3">
                                                                                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                    To="1.02" Duration="0:0:0.3">
                                                                                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                    To="1.0" Duration="0:0:0.25">
                                                                                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                    To="1.0" Duration="0:0:0.25">
                                                                                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   TextAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"
                                                                   Foreground="{Binding Percentage, Converter={StaticResource MarkToColorConverter}, Mode=OneWay}">
                                                            <Run Text="{Binding MarkAchieved, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                                            <Run Text="/" FontSize="10"/>
                                                            <Run Text="{Binding MarkPossible, StringFormat={}{0:F0}, Mode=OneWay}" FontSize="10"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%, Mode=OneWay}" FontSize="11"
                                                                   FontWeight="SemiBold" HorizontalAlignment="Center"
                                                                   Foreground="{Binding Percentage, Converter={StaticResource MarkToColorConverter}, Mode=OneWay}"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ui:CardExpander>

            <!-- No Assignments -->
            <ui:InfoBar Title="No assignments"
                        Message="No assignments available yet"
                        Severity="Informational"
                        IsOpen="{Binding AssignmentGroups.Count, Converter={StaticResource IntZeroToBoolConverter}}"
                        Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>

    <!-- Loading Overlay -->
    <Grid Background="{DynamicResource OverlayBrush}"
          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
        <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>

    <!-- Error Message -->
    <ui:InfoBar Title="Error"
                Message="{Binding ErrorMessage}"
                Severity="Error"
                IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                Margin="32,60,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="500"/>

    <!-- No Report Message -->
    <ui:InfoBar Title="No Report Available"
                Message="{Binding NoReportMessage}"
                Severity="Informational"
                IsOpen="{Binding NoReportMessage, Converter={StaticResource StringToBoolConverter}}"
                Margin="32,60,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="500"/>
    </Grid>
</Page>
