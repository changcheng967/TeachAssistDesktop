<Page x:Class="TeachAssistApp.Views.CourseDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Background="Transparent"
      Title="Course Detail - TeachAssist">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#FF010409" Padding="24,16" BorderBrush="#FF21262D" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource GhostButton}"
                        Padding="10,6"
                        Margin="0,0,16,0"
                        FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedCourse.Code}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#FF58A6FF"
                                   FontFamily="Segoe UI Variable"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding SelectedCourse.Name}"
                                   FontSize="14"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable"/>
                        <TextBlock Text="{Binding SelectedCourse.Room, StringFormat='   \x2022  {0}'}"
                                   FontSize="12"
                                   Foreground="#FF6E7681"
                                   FontFamily="Segoe UI Variable"/>
                        <TextBlock Text="{Binding SelectedCourse.Block, StringFormat='   \x2022  Block {0}'}"
                                   FontSize="12"
                                   Foreground="#FF6E7681"
                                   FontFamily="Segoe UI Variable"/>
                    </StackPanel>
                </StackPanel>

                <!-- Overall Mark -->
                <Border Grid.Column="2"
                        Width="100" Height="52"
                        CornerRadius="10"
                        Background="{Binding SelectedCourse.GradeColor, Converter={StaticResource StringToBrushConverter}}"
                        Padding="12">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedCourse.DisplayMark}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable Display"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,24,32,32"
                      Background="#FF0D1117">
            <Grid MaxWidth="900" HorizontalAlignment="Center">
                <StackPanel>

                    <!-- Grade Trends Section -->
                    <Border Visibility="{Binding HasTrends, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="#FF161B22" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                            BorderBrush="#FF21262D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Grade Trends" FontSize="14" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI Variable" Margin="0,0,0,14"/>
                            <ItemsControl ItemsSource="{Binding AssignmentTrendsDisplay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding AssignmentName}" FontSize="11" Foreground="#FF8B949E" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontFamily="Segoe UI Variable"/>
                                            <Border Grid.Column="1" Height="16" CornerRadius="3" Background="#FF21262D" Margin="8,0">
                                                <Border HorizontalAlignment="Left" CornerRadius="3" Background="{Binding TrendColor, Converter={StaticResource StringToBrushConverter}}">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                            <Binding Path="Mark" Mode="OneWay"/>
                                                            <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Border}" Path="ActualWidth" Mode="OneWay"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Mark, StringFormat=\{0:F0\}%}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding TrendColor}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Segoe UI Variable"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Category Performance (standard courses) -->
                    <Border Visibility="{Binding IsOEFormat, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                            Background="#FF161B22" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                            BorderBrush="#FF21262D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Category Performance" FontSize="14" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI Variable" Margin="0,0,0,14"/>
                            <ItemsControl ItemsSource="{Binding CategoryPerformance}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF0D1117" CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" Foreground="#FF8B949E" VerticalAlignment="Center" FontFamily="Segoe UI Variable"/>
                                                <Border Grid.Column="1" Height="8" CornerRadius="4" Background="#FF21262D" Margin="12,0">
                                                    <Border HorizontalAlignment="Left" CornerRadius="4" Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                                <Binding Path="Percentage" Mode="OneWay"/>
                                                                <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Border}" Path="ActualWidth" Mode="OneWay"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding Percentage, StringFormat={}{0:F1}%}" FontSize="13" FontWeight="Bold" Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}" VerticalAlignment="Center" FontFamily="Segoe UI Variable"/>
                                                <TextBlock Grid.Column="3" FontSize="11" Foreground="#FF6E7681" VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Segoe UI Variable">
                                                    <Run Text="{Binding AssignmentCount}"/><Run Text=" tasks"/>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Expectation Performance (OE courses) -->
                    <Border Visibility="{Binding IsOEFormat, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="#FF161B22" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                            BorderBrush="#FF21262D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Expectation Performance" FontSize="14" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI Variable" Margin="0,0,0,14"/>
                            <ItemsControl ItemsSource="{Binding ExpectationPerformance}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF0D1117" CornerRadius="8" Padding="16,12" Margin="0,0,8,8" MinWidth="150">
                                            <StackPanel>
                                                <Border Background="#FF58A6FF" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding Code}" FontSize="14" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI Variable"/>
                                                </Border>
                                                <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%}" FontSize="22" FontWeight="Bold" Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}" FontFamily="Segoe UI Variable Display" Margin="0,0,0,6"/>
                                                <Border Height="4" CornerRadius="2" Background="#FF21262D">
                                                    <Border HorizontalAlignment="Left" CornerRadius="2" Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                                <Binding Path="Percentage" Mode="OneWay"/>
                                                                <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Border}" Path="ActualWidth" Mode="OneWay"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Border>
                                                <TextBlock FontSize="11" Foreground="#FF6E7681" Margin="0,6,0,0" FontFamily="Segoe UI Variable">
                                                    <Run Text="{Binding AssignmentCount}"/><Run Text=" assessments"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Weight Breakdown -->
                    <Border Visibility="{Binding HasWeightData, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="#FF161B22" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                            BorderBrush="#FF21262D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Weight Breakdown" FontSize="14" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI Variable" Margin="0,0,0,14"/>
                            <ItemsControl ItemsSource="{Binding SelectedCourse.WeightTable.Weights}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="12" Foreground="#FF8B949E" VerticalAlignment="Center" FontFamily="Segoe UI Variable"/>
                                            <ProgressBar Grid.Column="1" Height="8" Value="{Binding Value, Mode=OneWay}" Maximum="100" Margin="12,0" VerticalAlignment="Center" Foreground="#FF238636" Background="#FF21262D"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat={}{0}%}" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Segoe UI Variable"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Assignments -->
                    <Border Background="#FF161B22" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                            BorderBrush="#FF21262D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Assignments" FontSize="14" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI Variable" Margin="0,0,0,14"/>
                            <ItemsControl ItemsSource="{Binding AssignmentGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF0D1117" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI Variable"/>
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Assignments}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FF161B22" CornerRadius="6" Padding="12,8" Margin="0,0,6,4" MinWidth="120">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold" Foreground="#FF6E7681" Margin="0,0,0,4" TextAlignment="Center"/>
                                                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="{Binding Percentage, Converter={StaticResource MarkToColorConverter}, Mode=OneWay}" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display">
                                                                        <Run Text="{Binding MarkAchieved, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                                                        <Run Text="/" FontSize="11"/>
                                                                        <Run Text="{Binding MarkPossible, StringFormat={}{0:F0}, Mode=OneWay}" FontSize="11"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding Percentage, Converter={StaticResource MarkToColorConverter}, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- No Assignments -->
                    <Border Visibility="{Binding AssignmentGroups.Count, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                            Background="#FF161B22" CornerRadius="10" Padding="40"
                            BorderBrush="#FF21262D" BorderThickness="1">
                        <TextBlock Text="No assignments available yet" FontSize="14" Foreground="#FF8B949E" HorizontalAlignment="Center" FontFamily="Segoe UI Variable"/>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1"
              Background="#CC000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="40" Height="40" BorderThickness="3" BorderBrush="#FF58A6FF" CornerRadius="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.RenderTransform><RotateTransform Angle="0"/></Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </Grid>

        <!-- Error Message -->
        <Border Grid.Row="1"
                Background="#FF161B22"
                CornerRadius="10"
                Padding="20"
                Margin="32,60,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                BorderBrush="#FFF85149"
                BorderThickness="1"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FFF85149" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF8B949E" TextWrapping="Wrap" FontSize="13" FontFamily="Segoe UI Variable" MaxWidth="400"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
