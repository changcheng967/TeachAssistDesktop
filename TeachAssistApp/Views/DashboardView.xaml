<Page x:Class="TeachAssistApp.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:TeachAssistApp.Helpers"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Loaded="Page_Loaded">

    <Grid Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Title + School Name -->
        <Grid Grid.Row="0" Margin="32,28,32,0" x:Name="HeaderRow">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="My Grades"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SchoolName}"
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ui:Button Grid.Column="1" Content="Refresh"
                       Command="{Binding LoadCoursesCommand}"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon ArrowSyncCheckmark24}"
                       VerticalAlignment="Top"
                       Margin="0,4,0,0"
                       />
        </Grid>

        <!-- Stats Row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="32,24,32,0" x:Name="StatsRow">
            <ui:Card x:Name="StatAvg" MinWidth="160" Margin="0,0,12,0" Padding="20,16"
                     Opacity="0" RenderTransformOrigin="0.5,1">
                <ui:Card.RenderTransform>
                    <TranslateTransform Y="20"/>
                </ui:Card.RenderTransform>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="ChartMultiple24"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,8,0"/>
                        <TextBlock Text="Average" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="AvgText"
                               Text="{Binding AverageMark, StringFormat={}{0:F1}%}"
                               FontSize="28" FontWeight="Bold"
                               helpers:NumericCounterBehavior.Animated="True"
                               helpers:NumericCounterBehavior.TargetValue="{Binding AverageMark}"/>
                </StackPanel>
            </ui:Card>

            <ui:Card x:Name="StatGpa" MinWidth="140" Margin="0,0,12,0" Padding="20,16"
                     Opacity="0" RenderTransformOrigin="0.5,1">
                <ui:Card.RenderTransform>
                    <TranslateTransform Y="20"/>
                </ui:Card.RenderTransform>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="People24"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,8,0"/>
                        <TextBlock Text="GPA" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Gpa}"
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </ui:Card>

            <ui:Card x:Name="StatCourses" MinWidth="140" Padding="20,16"
                     Opacity="0" RenderTransformOrigin="0.5,1">
                <ui:Card.RenderTransform>
                    <TranslateTransform Y="20"/>
                </ui:Card.RenderTransform>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="Book24"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,8,0"/>
                        <TextBlock Text="Courses" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding CourseCount}"
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Course List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="32,20,32,32">
            <ItemsControl x:Name="CourseItemsControl" ItemsSource="{Binding Courses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardAction Margin="0,0,0,8" MinHeight="68" Padding="16,12"
                                        Command="{Binding DataContext.SelectCourseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        RenderTransformOrigin="0.5,1">
                            <ui:CardAction.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </ui:CardAction.RenderTransform>
                            <ui:CardAction.Style>
                                <Style TargetType="ui:CardAction">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                            To="-2" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                            To="0" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsLunch}" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding MarkStatus}" Value="No mark posted">
                                            <Setter Property="Opacity" Value="0.7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:CardAction.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Code}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLunch}" Value="True">
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Visibility="{Binding MarkStatus, Converter={StaticResource StringToVisibilityConverter}}"
                                               Text="{Binding MarkStatus}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding DisplayMark}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLunch}" Value="True">
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                    <Setter Property="FontSize" Value="13"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="3"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0">
                                    <Run Text="P"/><Run Text="{Binding Block}"/>
                                </TextBlock>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding Room}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </ui:CardAction>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              Background="{DynamicResource OverlayBrush}"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,16"/>
                <TextBlock Text="Loading grades..."
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Empty State -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="BookQuestionMark24" FontSize="48"
                                   Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="No Courses Found" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Your courses will appear here once marks are published" FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <ui:Button Content="Refresh" Command="{Binding LoadCoursesCommand}" Appearance="Primary" Icon="{ui:SymbolIcon ArrowSync24}"/>
            </StackPanel>
        </Grid>

        <!-- Error Message -->
        <ui:InfoBar Grid.Row="2"
                    Title="Error"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                    Margin="32,60,32,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    MaxWidth="500"/>
    </Grid>
</Page>
