<Page x:Class="TeachAssistApp.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:TeachAssistApp.Helpers"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Loaded="Page_Loaded">

    <Grid Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             HERO SECTION
             ═══════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="32,28,32,0" x:Name="HeroSection">

            <!-- Header: Title + Refresh -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="My Grades"
                               Style="{StaticResource GradientHeading}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SchoolName}"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <ui:Button Grid.Column="1" Content="Refresh"
                           Command="{Binding LoadCoursesCommand}"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon ArrowSyncCheckmark24}"
                           VerticalAlignment="Top"
                           Margin="0,4,0,0"/>
            </Grid>

            <!-- Hero Stats Card with elevated shadow -->
            <Border x:Name="HeroStatCard" CornerRadius="16" Padding="0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Effect="{StaticResource CardHoverShadow}"
                    Opacity="0" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <TranslateTransform Y="20"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Gradient accent bar on left -->
                    <Border Grid.Column="0" CornerRadius="16,0,0,16"
                            Background="{StaticResource AccentGradient}"/>

                    <!-- Stats content -->
                    <Grid Grid.Column="1" Margin="28,24,28,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Big Average Number with animated counter -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="AVERAGE" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding AverageMark, StringFormat={}{0:F1}%}"
                                       FontSize="48" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       helpers:NumericCounterBehavior.Animated="True"
                                       helpers:NumericCounterBehavior.TargetValue="{Binding AverageMark}"/>
                        </StackPanel>

                        <!-- Vertical divider -->
                        <Border Grid.Column="1" Width="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                VerticalAlignment="Stretch" Margin="0,4,0,4"/>

                        <!-- Supporting stats -->
                        <WrapPanel Grid.Column="2" Orientation="Horizontal"
                                   VerticalAlignment="Center" HorizontalAlignment="Right">
                            <!-- GPA -->
                            <StackPanel Margin="28,0,0,0" HorizontalAlignment="Center">
                                <TextBlock Text="GPA" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Gpa}" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <!-- Courses -->
                            <StackPanel Margin="28,0,0,0" HorizontalAlignment="Center">
                                <TextBlock Text="COURSES" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CourseCount}" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </WrapPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Animated progress bar under hero -->
            <ProgressBar x:Name="HeroProgressBar" Margin="0,14,0,0"
                         Style="{StaticResource GradientProgressBar}"
                         Height="4"
                         Value="{Binding AverageMark, Mode=OneWay}" Maximum="100"
                         Opacity="0"/>

            <!-- Section label -->
            <TextBlock x:Name="CourseSectionLabel" Text="Courses"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,28,0,14"
                       Opacity="0"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════
             COURSE LIST
             ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,0,32,32">
            <ItemsControl x:Name="CourseItemsControl" ItemsSource="{Binding Courses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Course card with shadow and grade color accent -->
                        <Border Margin="0,0,0,10" CornerRadius="12"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="1.02" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                            To="0,0,0,10" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="1.0" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Grade color accent bar -->
                                <Border Grid.Column="0" CornerRadius="12,0,0,12"
                                        Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>

                                <!-- Clickable content -->
                                <Button Grid.Column="1" Grid.ColumnSpan="4"
                                        Command="{Binding DataContext.SelectCourseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{x:Null}"
                                        Background="Transparent" BorderThickness="0"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Grid Margin="20,16,20,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Course code -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Code}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLunch}" Value="True">
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Course name + status + mini grade bar -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Visibility="{Binding MarkStatus, Converter={StaticResource StringToVisibilityConverter}}"
                                                       Text="{Binding MarkStatus}"/>
                                            <!-- Mini grade progress bar -->
                                            <ProgressBar Height="4" Margin="0,6,60,0"
                                                         Style="{StaticResource GradeProgressBar}"
                                                         Value="{Binding NumericMark, Mode=OneWay}" Maximum="100"
                                                         Visibility="{Binding HasValidMark, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                         Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>
                                        </StackPanel>

                                        <!-- Grade circle indicator -->
                                        <Border Grid.Column="2" Width="52" Height="52" CornerRadius="26"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding HasValidMark, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Border CornerRadius="24" Margin="3"
                                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                                <Grid>
                                                    <!-- Colored ring -->
                                                    <Ellipse Stroke="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                             StrokeThickness="2.5" Fill="Transparent" Margin="2"
                                                             Opacity="0.4"/>
                                                    <!-- Grade text -->
                                                    <TextBlock Text="{Binding DisplayMark}"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </Border>

                                        <!-- Fallback for lunch/non-graded -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayMark}"
                                                   Visibility="{Binding HasValidMark, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLunch}" Value="True">
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Block + Room -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" Padding="6,3" Margin="0,0,6,0">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                    <Run Text="P"/><Run Text="{Binding Block}"/>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Room, StringFormat='Rm {0}'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2"
              Background="{DynamicResource OverlayBrush}"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,16"/>
                <TextBlock Text="Loading grades..."
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Empty State -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="16" Margin="0,0,0,20"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="BookQuestionMark24" FontSize="28"
                                   Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="No Courses Found" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Your courses will appear here once marks are published" FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <ui:Button Content="Refresh" Command="{Binding LoadCoursesCommand}"
                           Appearance="Primary" Icon="{ui:SymbolIcon ArrowSync24}"/>
            </StackPanel>
        </Grid>

        <!-- Error Message -->
        <ui:InfoBar Title="Error"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                    Margin="32,60,32,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    MaxWidth="500"/>
    </Grid>
</Page>
