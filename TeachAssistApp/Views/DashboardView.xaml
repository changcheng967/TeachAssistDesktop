<Page x:Class="TeachAssistApp.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1200"
      Background="Transparent"
      Title="Dashboard - TeachAssist"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="CourseRow" TargetType="Border">
            <Setter Property="Background" Value="#FF161B22"/>
            <Setter Property="BorderBrush" Value="#FF21262D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="16,14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1C2128"/>
                    <Setter Property="BorderBrush" Value="#FF30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero Stats Bar -->
        <Border Grid.Row="0" Background="#FF010409" Padding="32,24">
            <Border BorderBrush="#FF21262D" BorderThickness="0,0,0,1" Padding="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Title -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="My Grades"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable Display"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Pierre Elliott Trudeau High School"
                                   FontSize="13"
                                   Foreground="#FF6E7681"
                                   FontFamily="Segoe UI Variable"/>
                    </StackPanel>

                    <!-- Right: Stat pills + Actions -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                        <Border Background="#FF161B22" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#FF58A6FF" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display">
                                    <Run Text="{Binding AverageMark, StringFormat={}{0:F1}}"/>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#FF6E7681" VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="Segoe UI Variable">
                                    % avg
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="#FF161B22" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#FF238636" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display">
                                    <Run Text="{Binding Gpa}"/>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#FF6E7681" VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="Segoe UI Variable">
                                    GPA
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="#FF161B22" CornerRadius="8" Padding="16,10" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#FFD29922" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display">
                                    <Run Text="{Binding CourseCount}"/>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#FF6E7681" VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="Segoe UI Variable">
                                    courses
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Click="QuickActions_Click"
                                Style="{StaticResource GhostButton}"
                                Padding="12,8" FontSize="12" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Actions" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu Background="#FF161B22" Foreground="White" FontSize="13">
                                    <MenuItem Header="Grade Trends" Command="{Binding ViewTrendsCommand}" Background="#FF161B22" Foreground="White" Padding="12,8">
                                        <MenuItem.Icon><TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" Foreground="#FF58A6FF"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="What-If Calculator" Command="{Binding WhatIfCommand}" Background="#FF161B22" Foreground="White" Padding="12,8">
                                        <MenuItem.Icon><TextBlock Text="&#xE789;" FontFamily="Segoe MDL2 Assets" Foreground="#FFD29922"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Grade Goals" Command="{Binding GradeGoalsCommand}" Background="#FF161B22" Foreground="White" Padding="12,8">
                                        <MenuItem.Icon><TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" Foreground="#FF238636"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Export All Grades" Command="{Binding ExportCommand}" Background="#FF161B22" Foreground="White" Padding="12,8">
                                        <MenuItem.Icon><TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" Foreground="#FF58A6FF"/></MenuItem.Icon>
                                    </MenuItem>
                                    <Separator Background="#FF30363D"/>
                                    <MenuItem Header="Refresh" Command="{Binding LoadCoursesCommand}" Background="#FF161B22" Foreground="White" Padding="12,8">
                                        <MenuItem.Icon><TextBlock Text="&#xE117;" FontFamily="Segoe MDL2 Assets" Foreground="#FF238636"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Command="{Binding LoadCoursesCommand}" Style="{StaticResource PrimaryButton}" Padding="12,8" FontSize="12" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE117;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Refresh" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                        <Button Click="Settings_Click" Style="{StaticResource GhostButton}" Padding="12,8" FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Course List -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,20,32,32"
                      Background="#FF0D1117">
            <Grid MaxWidth="900" HorizontalAlignment="Center">
                <!-- Column Headers -->
                <Grid Margin="0,0,0,10" Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Code" FontSize="11" FontWeight="SemiBold" Foreground="#FF6E7681" VerticalAlignment="Center" FontFamily="Segoe UI Variable"/>
                    <TextBlock Grid.Column="1" Text="Course" FontSize="11" FontWeight="SemiBold" Foreground="#FF6E7681" VerticalAlignment="Center" Margin="16,0,0,0" FontFamily="Segoe UI Variable"/>
                    <TextBlock Grid.Column="2" Text="Mark" FontSize="11" FontWeight="SemiBold" Foreground="#FF6E7681" VerticalAlignment="Center" Margin="16,0,0,0" FontFamily="Segoe UI Variable"/>
                    <TextBlock Grid.Column="3" Text="Block" FontSize="11" FontWeight="SemiBold" Foreground="#FF6E7681" VerticalAlignment="Center" Margin="16,0,0,0" FontFamily="Segoe UI Variable"/>
                    <TextBlock Grid.Column="4" Text="Room" FontSize="11" FontWeight="SemiBold" Foreground="#FF6E7681" VerticalAlignment="Center" Margin="16,0,0,0" FontFamily="Segoe UI Variable"/>
                </Grid>

                <!-- Course Rows -->
                <ItemsControl ItemsSource="{Binding Courses}" x:Name="CourseItemsControl" Margin="0,32,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CourseRow}">
                                <Border.InputBindings>
                                    <MouseBinding Command="{Binding DataContext.SelectCourseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                 CommandParameter="{Binding}"
                                                 MouseAction="LeftClick"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Course Code -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Code}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#FF58A6FF"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable"/>

                                    <!-- Course Name -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="16,0,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               FontFamily="Segoe UI Variable"/>

                                    <!-- Mark -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <!-- Grade dot -->
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Border.Effect>
                                                <DropShadowEffect Color="{Binding GradeColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                            </Border.Effect>
                                        </Border>
                                        <TextBlock Text="{Binding DisplayMark}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI Variable"/>
                                    </StackPanel>

                                    <!-- Block -->
                                    <TextBlock Grid.Column="3"
                                               FontSize="13"
                                               Foreground="#FF8B949E"
                                               VerticalAlignment="Center"
                                               Margin="16,0,0,0"
                                               FontFamily="Segoe UI Variable">
                                        <Run Text="P"/><Run Text="{Binding Block}"/>
                                    </TextBlock>

                                    <!-- Room -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding Room}"
                                               FontSize="13"
                                               Foreground="#FF6E7681"
                                               VerticalAlignment="Center"
                                               Margin="16,0,0,0"
                                               FontFamily="Segoe UI Variable"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1"
              Background="#DD0D1117"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="48" Height="48"
                        BorderThickness="3"
                        BorderBrush="#FF58A6FF"
                        CornerRadius="24"
                        Margin="0,0,0,16">
                    <Border.RenderTransform>
                        <RotateTransform Angle="0"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                   From="0" To="360" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
                <TextBlock Text="Loading grades..."
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI Variable Display"/>
            </StackPanel>
        </Grid>

        <!-- Empty State -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#FF30363D" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="No Courses Found" Foreground="White" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display" Margin="0,0,0,8"/>
                <TextBlock Text="Your courses will appear here once marks are published" Foreground="#FF8B949E" FontSize="13" HorizontalAlignment="Center" FontFamily="Segoe UI Variable" Margin="0,0,0,24"/>
                <Button Command="{Binding LoadCoursesCommand}" Style="{StaticResource PrimaryButton}" Padding="20,10" FontSize="13">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE117;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Error Message -->
        <Border Grid.Row="1"
                Background="#FF161B22"
                CornerRadius="10"
                Padding="20"
                Margin="32,60,32,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                BorderBrush="#FFF85149"
                BorderThickness="1"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FFF85149" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF8B949E" TextWrapping="Wrap" FontSize="13" FontFamily="Segoe UI Variable" MaxWidth="400"/>
                    <Button Command="{Binding LoadCoursesCommand}" Style="{StaticResource GhostButton}" Padding="8,4" FontSize="12" Margin="0,10,0,0">
                        <TextBlock Text="Try Again"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
