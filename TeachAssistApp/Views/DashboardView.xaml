<Page x:Class="TeachAssistApp.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:TeachAssistApp.Helpers"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Loaded="Page_Loaded">

    <Grid Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             HERO SECTION — Bento grid layout
             ═══════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="32,28,32,0" x:Name="HeroSection">

            <!-- Header row -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="My Grades"
                               Style="{StaticResource GradientHeading}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SchoolName}"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>

                <ui:Button Grid.Column="1" Content="Refresh"
                           Command="{Binding LoadCoursesCommand}"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon ArrowSyncCheckmark24}"
                           VerticalAlignment="Top"
                           Margin="0,4,0,0"/>
            </Grid>

            <!-- Bento stat grid: 2 columns, big average on left, stacked stats on right -->
            <Grid x:Name="BentoGrid" Margin="0,0,0,20" Opacity="0" RenderTransformOrigin="0.5,1">
                <Grid.RenderTransform>
                    <TranslateTransform Y="16"/>
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LEFT: Big average card — grade-colored accent -->
                <Border Grid.Column="0" Style="{StaticResource BentoHeroCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Grade-colored accent bar -->
                        <Border Grid.Column="0" CornerRadius="14,0,0,14"
                                Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,16,20,16">
                            <TextBlock Text="AVERAGE" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,8" Opacity="0.8"/>
                            <TextBlock Text="{Binding AverageMark, StringFormat={}{0:F1}%}"
                                       FontSize="52" FontWeight="Bold"
                                       Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                       helpers:NumericCounterBehavior.Animated="True"
                                       helpers:NumericCounterBehavior.TargetValue="{Binding AverageMark}"/>

                            <!-- Grade label — motivational -->
                            <TextBlock Text="{Binding GradeLabel}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0" Opacity="0.7"/>

                            <!-- Thin progress bar -->
                            <ProgressBar Margin="0,14,0,0"
                                         Style="{StaticResource ThinProgressBar}"
                                         Value="{Binding AverageMark, Mode=OneWay}" Maximum="100"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT: Stacked GPA + Courses cards -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- GPA card -->
                    <Border Grid.Row="0" Style="{StaticResource BentoCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                    Background="{StaticResource WarmGradient}"/>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="GPA" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,4" Opacity="0.8"/>
                                <TextBlock Text="{Binding Gpa}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Courses card -->
                    <Border Grid.Row="2" Style="{StaticResource BentoCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                    Background="{StaticResource SuccessGradient}"/>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="COURSES" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,4" Opacity="0.8"/>
                                <TextBlock Text="{Binding CourseCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Section label -->
            <TextBlock x:Name="CourseSectionLabel" Text="COURSES"
                       Style="{StaticResource SectionHeader}"
                       Margin="0,8,0,10"
                       Opacity="0"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════
             COURSE LIST — Clean, spaced cards
             ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                      helpers:SmoothScrollBehavior.IsEnabled="True" Padding="32,0,32,32">
            <ItemsControl x:Name="CourseItemsControl" ItemsSource="{Binding Courses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Course card -->
                        <Border Margin="0,0,0,8" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Effect="{StaticResource CardDefaultShadow}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="1.006" Duration="0:0:0.35">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="1.0" Duration="0:0:0.3">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Grade color accent bar -->
                                <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                        Background="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"/>

                                <!-- Clickable content -->
                                <Button Grid.Column="1"
                                        Command="{Binding DataContext.SelectCourseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{x:Null}"
                                        Background="Transparent" BorderThickness="0"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Grid Margin="16,14,16,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Course code -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Code}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Course name + status -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Visibility="{Binding MarkStatus, Converter={StaticResource StringToVisibilityConverter}}"
                                                       Text="{Binding MarkStatus}"/>
                                        </StackPanel>

                                        <!-- Grade + Block -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DisplayMark}"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{Binding GradeColor, Converter={StaticResource StringToBrushConverter}}"
                                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" Padding="6,3">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                    <Run Text="P"/><Run Text="{Binding Block}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2"
              Background="{DynamicResource OverlayBrush}"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="10" Margin="0,0,0,20"
                        HorizontalAlignment="Center" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#6366F1" BlurRadius="20" ShadowDepth="0" Opacity="0.3" Direction="0"/>
                    </Border.Effect>
                    <Image Source="/logo.png" Stretch="UniformToFill"/>
                </Border>
                <ui:ProgressRing IsIndeterminate="True" Width="32" Height="32" Margin="0,0,0,16"
                                 HorizontalAlignment="Center"/>
                <TextBlock Text="Loading grades..."
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Empty State -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="72" Height="72" CornerRadius="10" Margin="0,0,0,24"
                        HorizontalAlignment="Center" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#6366F1" BlurRadius="20" ShadowDepth="0" Opacity="0.15" Direction="0"/>
                    </Border.Effect>
                    <Image Source="/logo.png" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="No Courses Found" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Your courses will appear here once marks are published" FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <ui:Button Content="Refresh" Command="{Binding LoadCoursesCommand}"
                           Appearance="Primary" Icon="{ui:SymbolIcon ArrowSync24}"/>
            </StackPanel>
        </Grid>

        <!-- Error Message -->
        <ui:InfoBar Title="Error"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                    Margin="32,60,32,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    MaxWidth="500"/>
    </Grid>
</Page>
