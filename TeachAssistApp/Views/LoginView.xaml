<Page x:Class="TeachAssistApp.Views.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Brand -->
        <Border Grid.Column="0" Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
                <!-- Logo -->
                <Border Width="80" Height="80"
                        CornerRadius="20"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,32">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF58A6FF" Offset="0"/>
                            <GradientStop Color="#FF238636" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="TA"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="TeachAssist"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Desktop"
                           FontSize="36"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF58A6FF" Offset="0"/>
                            <GradientStop Color="#FF238636" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="Track your YRDSB grades with style."
                           FontSize="16"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20" Padding="12,8" Margin="0,0,8,0">
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" Foreground="#FF58A6FF"/>
                            <Run Text="  Grade Trends"/>
                        </TextBlock>
                    </Border>
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20" Padding="12,8" Margin="0,0,8,0">
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" Foreground="#FF238636"/>
                            <Run Text="  Goal Tracking"/>
                        </TextBlock>
                    </Border>
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20" Padding="12,8">
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="&#xE789;" FontFamily="Segoe MDL2 Assets" Foreground="#FFD29922"/>
                            <Run Text="  What-If Calc"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Right Panel: Login Form -->
        <Border Grid.Column="1" Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="48">
                <StackPanel VerticalAlignment="Center" MinHeight="500">
                    <TextBlock Text="Welcome back"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Sign in with your YRDSB student credentials"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,32"/>

                    <!-- Error Message -->
                    <ui:InfoBar Title="Login Failed"
                                Message="{Binding ErrorMessage}"
                                Severity="Error"
                                IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                                Margin="0,0,0,20"/>

                    <!-- Student Number Field -->
                        <TextBlock Text="Student Number"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <ui:TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Enter your student number"
                                    Icon="{ui:SymbolIcon Person24}"
                                    Margin="0,0,0,16">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                    <!-- Password Field -->
                        <TextBlock Text="Password"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <ui:PasswordBox x:Name="PasswordBox"
                                        PlaceholderText="Enter your password"
                                        PasswordChanged="PasswordBox_PasswordChanged"
                                        KeyDown="PasswordBox_KeyDown"
                                        Margin="0,0,0,20"/>

                    <!-- Remember Me -->
                    <ui:ToggleSwitch Content="Remember me"
                                     IsChecked="{Binding RememberMe}"
                                     Margin="0,0,0,24"/>

                    <!-- Login Button -->
                    <ui:Button Content="Sign In"
                               Command="{Binding LoginCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               FontSize="15"
                               Height="44"
                               Margin="0,0,0,16"/>

                    <!-- Demo Hint -->
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            Padding="12,10"
                            CornerRadius="8"
                            HorizontalAlignment="Center">
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                            <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets"/>
                            <Run Text=" Type "/>
                            <Run Text="demo" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Run Text=" to test with sample grades"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.ColumnSpan="2"
              Background="#AA000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,20"/>
                <TextBlock Text="Signing in..."
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
