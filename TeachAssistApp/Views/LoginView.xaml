<Page x:Class="TeachAssistApp.Views.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             LEFT PANEL: BRAND — with depth layers
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
            <Grid>
                <!-- Layered background: gradient tint -->
                <Border Background="{StaticResource AccentGradientSubtle}" Opacity="0.10"/>

                <!-- Decorative floating circles for depth -->
                <Canvas>
                    <Ellipse Canvas.Left="60" Canvas.Top="80" Width="180" Height="180"
                             Fill="#6366F1" Opacity="0.06"/>
                    <Ellipse Canvas.Right="40" Canvas.Bottom="60" Width="240" Height="240"
                             Fill="#8B5CF6" Opacity="0.07"/>
                    <Ellipse Canvas.Left="200" Canvas.Bottom="120" Width="100" Height="100"
                             Fill="#F59E0B" Opacity="0.06"/>
                </Canvas>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">

                    <!-- Logo with soft glow -->
                    <Border x:Name="BrandLogo" Width="96" Height="96"
                            CornerRadius="22"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,32"
                            ClipToBounds="True"
                            Opacity="0" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect Color="#6366F1" BlurRadius="32" ShadowDepth="0" Opacity="0.35" Direction="0"/>
                        </Border.Effect>
                        <Image Source="/logo.png" Stretch="UniformToFill"/>
                    </Border>

                    <!-- Gradient accent line -->
                    <Border x:Name="BrandAccentLine" Width="200" Height="3"
                            CornerRadius="1.5"
                            HorizontalAlignment="Center"
                            Background="{StaticResource AccentGradientHorizontal}"
                            Margin="0,0,0,32"
                            Opacity="0"/>

                    <TextBlock x:Name="BrandTitle" Text="TeachAssist Desktop"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"
                               Opacity="0" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="12"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <TextBlock x:Name="BrandSubtitle" Text="Track your YRDSB grades with style."
                               FontSize="15"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"
                               Opacity="0" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="12"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- Feature badges — clean pills with colored dots -->
                    <StackPanel x:Name="BrandBadges" HorizontalAlignment="Center" Orientation="Horizontal" Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="12"/>
                        </StackPanel.RenderTransform>

                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="20" Padding="14,8" Margin="0,0,8,0"
                                Effect="{StaticResource CardDefaultShadow}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="7" Height="7" CornerRadius="4" Margin="0,0,8,0"
                                        Background="{StaticResource InfoBrush}" VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center">Grade Trends</TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="20" Padding="14,8" Margin="0,0,8,0"
                                Effect="{StaticResource CardDefaultShadow}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="7" Height="7" CornerRadius="4" Margin="0,0,8,0"
                                        Background="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center">Goal Tracking</TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="20" Padding="14,8"
                                Effect="{StaticResource CardDefaultShadow}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="7" Height="7" CornerRadius="4" Margin="0,0,8,0"
                                        Background="{StaticResource WarningBrush}" VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center">What-If Calc</TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             RIGHT PANEL: LOGIN FORM
             ═══════════════════════════════════════════════════════ -->
        <Border x:Name="FormPanel" Grid.Column="1"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0"
                Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform X="20"/>
            </Border.RenderTransform>

            <Grid>
                <!-- Gradient accent line at top of form -->
                <Border Height="3" VerticalAlignment="Top"
                        Background="{StaticResource AccentGradientHorizontal}"
                        Panel.ZIndex="1"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="44" Margin="0,3,0,0">
                    <StackPanel VerticalAlignment="Center" MinHeight="480">
                        <TextBlock Text="Welcome back"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Sign in with your YRDSB student credentials"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,28"/>

                        <!-- Error Message -->
                        <ui:InfoBar Title="Login Failed"
                                    Message="{Binding ErrorMessage}"
                                    Severity="Error"
                                    IsOpen="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                                    Margin="0,0,0,20"/>

                        <!-- Student Number -->
                        <TextBlock Text="Student Number"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <ui:TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Enter your student number"
                                    Icon="{ui:SymbolIcon Person24}"
                                    Margin="0,0,0,14">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                        <!-- Password -->
                        <TextBlock Text="Password"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <ui:PasswordBox x:Name="PasswordBox"
                                        PlaceholderText="Enter your password"
                                        PasswordChanged="PasswordBox_PasswordChanged"
                                        KeyDown="PasswordBox_KeyDown"
                                        Margin="0,0,0,18"/>

                        <!-- Remember Me -->
                        <ui:ToggleSwitch Content="Remember me"
                                         IsChecked="{Binding RememberMe}"
                                         Margin="0,0,0,24"/>

                        <!-- Login Button -->
                        <ui:Button Content="Sign In"
                                   Command="{Binding LoginCommand}"
                                   Appearance="Primary"
                                   HorizontalAlignment="Stretch"
                                   FontSize="15"
                                   Height="44"
                                   Margin="0,0,0,20"/>

                        <!-- Demo Hint -->
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Padding="12,8"
                                CornerRadius="8"
                                HorizontalAlignment="Center">
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                <Run Text="Type "/>
                                <Run Text="demo" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <Run Text=" to test with sample grades"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.ColumnSpan="2"
              Background="{DynamicResource OverlayBrush}"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,20"/>
                <TextBlock Text="Signing in..."
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
