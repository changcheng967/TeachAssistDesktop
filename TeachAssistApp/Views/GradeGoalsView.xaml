<Window x:Class="TeachAssistApp.Views.GradeGoalsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grade Goals - TeachAssist"
        Height="720"
        Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF0D1117"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="#FF30363D">
    <Window.Effect>
        <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="0" Opacity="0.5"/>
    </Window.Effect>

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#FF161B22"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF8B949E"/>
        <SolidColorBrush x:Key="Accent" Color="#FF58A6FF"/>
        <SolidColorBrush x:Key="Success" Color="#FF238636"/>
        <SolidColorBrush x:Key="Warning" Color="#FFD29922"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#FF0D1117">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0"
                    Background="#FF010409"
                    Padding="24,16,24,16"
                    BorderBrush="#FF30363D"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32"
                                CornerRadius="8"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF58A6FF" Offset="0"/>
                                    <GradientStop Color="#FF238636" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF58A6FF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <TextBlock Text="&#xE7E8;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Grade Goals"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondary}"
                            BorderThickness="0"
                            FontSize="18"
                            Padding="10"
                            Cursor="Hand"
                            Width="40"
                            Height="40"
                            Command="{Binding CloseCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}"
                                                    Cursor="Hand">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFF85149"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28,20,28,28">
                <StackPanel>
                    <!-- Current Average -->
                    <Border Background="{StaticResource CardBackground}"
                            CornerRadius="12"
                            Padding="28"
                            Margin="0,0,0,24"
                            BorderBrush="#FF30363D"
                            BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Current Average"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,8"/>
                        <TextBlock FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}">
                            <Run Text="{Binding CurrentAverage, StringFormat=\{0:F1\}%}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <TextBlock Text="Goal"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,8"/>
                        <Border Background="{StaticResource Success}"
                                CornerRadius="8"
                                Padding="12,8">
                            <TextBlock FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White">
                                <Run Text="{Binding GoalPercent, StringFormat=\{0:F0\}%}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Progress to Goal -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Progress to Goal"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="{Binding ProgressToGoal, StringFormat=\{0:F1\}%}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Progress Bar -->
                    <Border Height="16"
                            CornerRadius="8"
                            Background="#FF21262D"
                            Margin="0,0,0,12">
                        <Border HorizontalAlignment="Left"
                                CornerRadius="8">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource PercentageConverter}">
                                    <Binding Path="ProgressToGoal" Mode="OneWay"/>
                                    <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Border}" Path="ActualWidth" Mode="OneWay"/>
                                </MultiBinding>
                            </Border.Width>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF58A6FF" Offset="0"/>
                                    <GradientStop Color="#FF238636" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>

                    <!-- Info -->
                    <Grid>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                            <Run Text="You need "/>
                            <Run Text="{Binding PointsNeeded, StringFormat=\{0:F1\}%}" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
                            <Run Text=" more to reach your goal"/>
                        </TextBlock>

                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Right"
                                   Visibility="{Binding OnTrack, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Run Text="✓ On track"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Goal Settings -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Set Your Goal"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,16"/>

                    <!-- Preset Goals -->
                    <ItemsControl ItemsSource="{Binding PresetGoals}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FF21262D"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,0,8,8"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF30363D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding DataContext.SetGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}"
                                                     CommandParameter="{Binding Percent}"
                                                     MouseAction="LeftClick"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Color}"
                                                   HorizontalAlignment="Center">
                                            <Run Text="{Binding Percent, StringFormat=\{0:F0\}%}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   HorizontalAlignment="Center">
                                            <Run Text="{Binding Label}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Custom Goal Input -->
                    <Grid Margin="0,12,0,0">
                        <TextBlock Text="Custom Goal:"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox Text="{Binding CustomGoal, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13"
                                     Padding="8"
                                     Width="80"
                                     Background="#FF21262D"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="#FF30363D"
                                     BorderThickness="1"
                                     VerticalAlignment="Center"/>

                            <Button Content="Set"
                                    Command="{Binding SetCustomGoalCommand}"
                                    Style="{StaticResource ModernButton}"
                                    Padding="12,8"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

                    <!-- Motivational Message -->
                    <Border Background="#FF21262D"
                            CornerRadius="8"
                            Padding="18"
                            Margin="0,0,0,0"
                            Visibility="{Binding ShowMotivation, Converter={StaticResource BooleanToVisibilityConverter}}"
                            BorderBrush="#FF30363D"
                            BorderThickness="1">
                        <TextBlock Text="{Binding MotivationalMessage}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
