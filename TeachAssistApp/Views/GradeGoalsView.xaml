<ui:FluentWindow x:Class="TeachAssistApp.Views.GradeGoalsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Grade Goals - TeachAssist"
        Height="720" Width="780"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="Grade Goals" />

        <Border Height="3" VerticalAlignment="Top" Margin="0,32,0,0"
                Background="{StaticResource AccentGradientHorizontal}"/>

        <ScrollViewer Margin="0,35,0,0" VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel>
                <!-- Hero: Current Average + Target -->
                <Border Margin="0,0,0,20" CornerRadius="14"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        Effect="{StaticResource CardElevatedShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="14,0,0,14" Background="{StaticResource AccentGradient}"/>
                        <StackPanel Grid.Column="1" Margin="24,20">
                            <TextBlock Text="Current Average" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CurrentAverage, StringFormat={}{0:F1}%}" FontSize="44" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="24,20" VerticalAlignment="Center">
                            <TextBlock Text="Target" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                            <Border Background="{StaticResource SuccessGradient}" CornerRadius="6" Padding="12,6" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding GoalPercent, StringFormat={}{0:F0}%}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Progress to Goal -->
                <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        Effect="{StaticResource CardDefaultShadow}" Padding="16,14" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Progress to Goal" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ProgressToGoal, StringFormat={}{0:F1}%}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="8" CornerRadius="4" Margin="0,0,0,14"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <Border CornerRadius="4" HorizontalAlignment="Left"
                                    Background="{StaticResource AccentGradientHorizontal}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentageConverter}">
                                        <Binding Path="ProgressToGoal"/>
                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                        <Grid>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="You need "/><Run Text="{Binding PointsNeeded, StringFormat={}{0:F1}%}" FontWeight="SemiBold"/><Run Text=" more"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"
                                       Visibility="{Binding OnTrack, Converter={StaticResource BooleanToVisibilityConverter}}">On track</TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Goal Settings -->
                <Border CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        Effect="{StaticResource CardDefaultShadow}" Padding="16,14" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Set Your Goal" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,14"/>

                        <ItemsControl ItemsSource="{Binding PresetGoals}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Custom clickable tile instead of CardAction -->
                                    <Border Margin="0,0,8,8" MinWidth="100" CornerRadius="8"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            Effect="{StaticResource CardDefaultShadow}" Padding="14,10" Cursor="Hand"
                                            MouseLeftButtonDown="PresetGoal_Click" Tag="{Binding Percent}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Percent, StringFormat={}{0:F0}%}" FontSize="20" FontWeight="Bold"
                                                       Foreground="{Binding Color, Converter={StaticResource StringToBrushConverter}}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Label}" FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,14,0,0">
                            <TextBlock Text="Custom Goal:" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:TextBox Text="{Binding CustomGoal, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="%" Width="80" VerticalAlignment="Center"/>
                                <ui:Button Content="Set" Command="{Binding SetCustomGoalCommand}"
                                           Appearance="Primary" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Motivational Message -->
                <ui:InfoBar Message="{Binding MotivationalMessage}" Severity="Informational"
                            IsOpen="{Binding ShowMotivation}" Margin="0,0,0,20"/>

                <ui:Button Content="Close" Command="{Binding CloseCommand}" Appearance="Secondary" HorizontalAlignment="Right"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
