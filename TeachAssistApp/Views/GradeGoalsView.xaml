<ui:FluentWindow x:Class="TeachAssistApp.Views.GradeGoalsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Grade Goals - TeachAssist"
        Height="720" Width="780"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="Grade Goals" />

        <!-- Gradient accent line -->
        <Border Height="3" VerticalAlignment="Top" Margin="0,32,0,0"
                Background="{StaticResource AccentGradientHorizontal}"/>

        <ScrollViewer Margin="0,35,0,0" VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel>
                <!-- Current Average & Goal — bento hero card -->
                <Border Margin="0,0,0,20" CornerRadius="14"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        Effect="{StaticResource CardElevatedShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="14,0,0,14"
                                Background="{StaticResource AccentGradient}"/>

                        <Grid Grid.Column="1" Margin="24,20">
                            <StackPanel>
                                <TextBlock Text="Current Average" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding CurrentAverage, StringFormat={}{0:F1}%}" FontSize="44" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="2" Margin="24,20" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="Target" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                            <ui:Badge Content="{Binding GoalPercent, StringFormat={}{0:F0}%}" Appearance="Success"
                                      FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Progress to Goal -->
                <ui:Card Margin="0,0,0,20">
                    <StackPanel Margin="16,14">
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Progress to Goal" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ProgressToGoal, StringFormat={}{0:F1}%}" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Gradient progress bar -->
                        <Border Height="10" CornerRadius="5" Margin="0,0,0,14"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <Border CornerRadius="5" HorizontalAlignment="Left"
                                    Background="{StaticResource AccentGradientHorizontal}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentageConverter}">
                                        <Binding Path="ProgressToGoal"/>
                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>

                        <Grid>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="You need "/>
                                <Run Text="{Binding PointsNeeded, StringFormat={}{0:F1}%}" FontWeight="SemiBold"/>
                                <Run Text=" more to reach your goal"/>
                            </TextBlock>

                            <TextBlock FontSize="12" Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Right"
                                       Visibility="{Binding OnTrack, Converter={StaticResource BooleanToVisibilityConverter}}">
                                On track
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Goal Settings -->
                <ui:Card Margin="0,0,0,20">
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Set Your Goal" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,14"/>

                        <!-- Preset Goals -->
                        <ItemsControl ItemsSource="{Binding PresetGoals}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:CardAction Margin="0,0,8,8" MinWidth="100"
                                                    Command="{Binding DataContext.SetGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}"
                                                    CommandParameter="{Binding Percent}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Percent, StringFormat={}{0:F0}%}" FontSize="20" FontWeight="Bold"
                                                       Foreground="{Binding Color, Converter={StaticResource StringToBrushConverter}}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Label}" FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:CardAction>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Custom Goal Input -->
                        <Grid Margin="0,14,0,0">
                            <TextBlock Text="Custom Goal:" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:TextBox Text="{Binding CustomGoal, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="%" Width="80" VerticalAlignment="Center"/>
                                <ui:Button Content="Set" Command="{Binding SetCustomGoalCommand}"
                                           Appearance="Primary" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Motivational Message -->
                <ui:InfoBar Message="{Binding MotivationalMessage}"
                            Severity="Informational"
                            IsOpen="{Binding ShowMotivation}"
                            Margin="0,0,0,20"/>

                <ui:Button Content="Close" Command="{Binding CloseCommand}" Appearance="Secondary"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
