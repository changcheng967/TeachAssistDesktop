<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Backgrounds -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FF0D1117"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF161B22"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#FF1C2128"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FF161B22"/>
    <SolidColorBrush x:Key="CardBackgroundHover" Color="#FF1C2128"/>
    <SolidColorBrush x:Key="CardBorder" Color="#FF30363D"/>

    <!-- Title Bar -->
    <SolidColorBrush x:Key="TitleBarBrush" Color="#FF010409"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FF8B949E"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#FF6E7681"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="Accent" Color="#FF58A6FF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF238636"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#FF2EA043"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="Success" Color="#FF238636"/>
    <SolidColorBrush x:Key="Warning" Color="#FFD29922"/>
    <SolidColorBrush x:Key="Danger" Color="#FFF85149"/>

    <!-- Semantic Backgrounds -->
    <SolidColorBrush x:Key="InputBackground" Color="#FF0D1117"/>
    <SolidColorBrush x:Key="SubtleBackground" Color="#FF21262D"/>
    <SolidColorBrush x:Key="MicaBackground" Color="#E50D1117"/>

    <!-- Grade Spectrum Colors -->
    <SolidColorBrush x:Key="GradeAPlus" Color="#FF1F6FEB"/>
    <SolidColorBrush x:Key="GradeA" Color="#FF238636"/>
    <SolidColorBrush x:Key="GradeB" Color="#FFD29922"/>
    <SolidColorBrush x:Key="GradeC" Color="#FFDB6D28"/>
    <SolidColorBrush x:Key="GradeD" Color="#FFf85149"/>
    <SolidColorBrush x:Key="GradeNA" Color="#FF30363D"/>

    <!-- Course Detail Category Colors -->
    <SolidColorBrush x:Key="KU_Color" Color="#FFFFFAA"/>
    <SolidColorBrush x:Key="T_Color" Color="#FFC0FEA4"/>
    <SolidColorBrush x:Key="C_Color" Color="#FFAFAFFF"/>
    <SolidColorBrush x:Key="A_Color" Color="#FFFFD490"/>
    <SolidColorBrush x:Key="F_Color" Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="O_Color" Color="#FFD0D0D0"/>

</ResourceDictionary>
