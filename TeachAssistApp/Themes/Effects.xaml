<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shadow Levels -->
    <DropShadowEffect x:Key="ShadowSmall" Color="#000000" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
    <DropShadowEffect x:Key="ShadowMedium" Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.25"/>
    <DropShadowEffect x:Key="ShadowLarge" Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>

    <!-- Card Shadow -->
    <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="12" ShadowDepth="0" Opacity="0.25"/>

    <!-- Accent Glow -->
    <DropShadowEffect x:Key="GlowAccent" Color="#FF58A6FF" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
    <DropShadowEffect x:Key="GlowSuccess" Color="#FF238636" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>

</ResourceDictionary>
