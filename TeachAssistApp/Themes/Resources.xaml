<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ══════════════════════════════════════════════════════════
         ACCENT GRADIENTS — Primary design identity
         ══════════════════════════════════════════════════════════ -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientSubtle" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#312E81" Offset="0"/>
        <GradientStop Color="#4C1D95" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientHorizontal" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#A78BFA" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientVertical" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glow effect for accent elements -->
    <DropShadowEffect x:Key="AccentGlow" Color="#6366F1" BlurRadius="20" ShadowDepth="0" Opacity="0.4" Direction="0"/>

    <!-- ══════════════════════════════════════════════════════════
         OVERLAY & STATUS COLORS
         ══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="OverlayBrush" Color="#99000000"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#2563EB"/>

    <!-- ══════════════════════════════════════════════════════════
         CARD ELEVATION & HOVER
         ══════════════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="CardHoverShadow" BlurRadius="16" ShadowDepth="4" Opacity="0.15" Direction="270"/>
    <DropShadowEffect x:Key="CardDefaultShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.06" Direction="270"/>

    <!-- ══════════════════════════════════════════════════════════
         TYPOGRAPHY SCALE
         ══════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="HeroFontSize">42</sys:Double>
    <sys:Double x:Key="DisplayFontSize">28</sys:Double>
    <sys:Double x:Key="H1FontSize">22</sys:Double>
    <sys:Double x:Key="H2FontSize">18</sys:Double>
    <sys:Double x:Key="BodyFontSize">14</sys:Double>
    <sys:Double x:Key="CaptionFontSize">12</sys:Double>

    <!-- ══════════════════════════════════════════════════════════
         BUTTON MICRO-ANIMATION (preserves base WPF-UI styling)
         Uses RenderTransform only — does NOT replace Button style
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="AnimatedButton" TargetType="ButtonBase">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="1.03" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.03" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="1.0" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.0" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="0.97" Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="0.97" Duration="0:0:0.08"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         GRADIENT ACCENT LINE — thin decorative bar
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="GradientAccentLine" TargetType="Border">
        <Setter Property="Height" Value="2"/>
        <Setter Property="Background" Value="{StaticResource AccentGradientHorizontal}"/>
        <Setter Property="CornerRadius" Value="1"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         ELEVATED CARD — card with default shadow for depth
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ElevatedCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Effect" Value="{StaticResource CardDefaultShadow}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.02" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.0" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         SECTION HEADER — styled label for settings-like sections
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         GRADIENT PROGRESS BAR — rounded, gradient-filled, animated
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="GradientProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <!-- Track -->
                        <Border x:Name="PART_Track" CornerRadius="3"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                        <!-- Fill -->
                        <Border x:Name="PART_Indicator" CornerRadius="3"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentGradientHorizontal}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Grade-colored progress bar -->
    <Style x:Key="GradeProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" CornerRadius="3"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                        <Border x:Name="PART_Indicator" CornerRadius="3"
                                HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         GRADIENT HEADING — gradient text effect for key titles
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="GradientHeading" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#A78BFA" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
