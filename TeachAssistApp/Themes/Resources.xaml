<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ══════════════════════════════════════════════════════════
         ACCENT — used sparingly, only on brand/hero elements
         ══════════════════════════════════════════════════════════ -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientSubtle" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#312E81" Offset="0"/>
        <GradientStop Color="#4C1D95" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientHorizontal" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#A78BFA" Offset="1"/>
    </LinearGradientBrush>

    <!-- Soft glow — very subtle -->
    <DropShadowEffect x:Key="AccentGlow" Color="#6366F1" BlurRadius="24" ShadowDepth="0" Opacity="0.2" Direction="0"/>

    <!-- ══════════════════════════════════════════════════════════
         OVERLAY & STATUS
         ══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="OverlayBrush" Color="#99000000"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#2563EB"/>

    <!-- ══════════════════════════════════════════════════════════
         SHADOWS — macOS-style: very soft, barely visible
         ══════════════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="CardHoverShadow" BlurRadius="24" ShadowDepth="6" Opacity="0.08" Direction="270"/>
    <DropShadowEffect x:Key="CardDefaultShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.04" Direction="270"/>

    <!-- ══════════════════════════════════════════════════════════
         TYPOGRAPHY
         ══════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="HeroFontSize">42</sys:Double>
    <sys:Double x:Key="DisplayFontSize">28</sys:Double>
    <sys:Double x:Key="H1FontSize">22</sys:Double>
    <sys:Double x:Key="H2FontSize">18</sys:Double>
    <sys:Double x:Key="BodyFontSize">14</sys:Double>
    <sys:Double x:Key="CaptionFontSize">12</sys:Double>

    <!-- ══════════════════════════════════════════════════════════
         BUTTON — subtle press, no scale on hover (macOS feel)
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="AnimatedButton" TargetType="ButtonBase">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsPressed" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="0.98" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="0.98" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="1.0" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.0" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         DECORATIVE ACCENT LINE
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="GradientAccentLine" TargetType="Border">
        <Setter Property="Height" Value="2"/>
        <Setter Property="Background" Value="{StaticResource AccentGradientHorizontal}"/>
        <Setter Property="CornerRadius" Value="1"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         ELEVATED CARD — barely visible shadow, gentle hover
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ElevatedCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Effect" Value="{StaticResource CardDefaultShadow}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.006" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.0" Duration="0:0:0.35">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Section header -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         PROGRESS BARS — rounded, clean
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="GradientProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" CornerRadius="3"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                        <Border x:Name="PART_Indicator" CornerRadius="3"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentGradientHorizontal}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="GradeProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" CornerRadius="3"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                        <Border x:Name="PART_Indicator" CornerRadius="3"
                                HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Gradient heading — used only on primary page titles -->
    <Style x:Key="GradientHeading" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#A78BFA" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
