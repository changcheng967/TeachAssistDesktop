<Window x:Class="TeachAssistApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TeachAssistApp"
        mc:Ignorable="d"
        Title="TeachAssist"
        Height="900"
        Width="1400"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D1117"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="(Window.Opacity)"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Minimal Title Bar -->
        <Grid Grid.Row="0" Background="#FF010409" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF58A6FF" Offset="0"/>
                            <GradientStop Color="#FF238636" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <TextBlock Text="TeachAssist"
                           FontSize="12"
                           Foreground="#FF8B949E"
                           FontFamily="Segoe UI Variable"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="Minimize_Click" Style="{StaticResource WindowControlButton}" Width="46" Height="32">
                    <Path Data="M0,8 L10,8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" StrokeStartLineCap="Round"/>
                </Button>
                <Button Click="Maximize_Click" Style="{StaticResource WindowControlButton}" Width="46" Height="32">
                    <Path Data="M0,0 L10,0 L10,10 L0,10 Z M1,1 L1,9 L9,9 L9,1 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="10" Height="10" StrokeThickness="0"/>
                </Button>
                <Button Click="Close_Click" Style="{StaticResource CloseButton}" Width="46" Height="32">
                    <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content Frame -->
        <Grid Grid.Row="1">
            <Frame x:Name="ContentFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"
                   ClipToBounds="True"/>
        </Grid>
    </Grid>
</Window>
