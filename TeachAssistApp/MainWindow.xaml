<ui:FluentWindow x:Class="TeachAssistApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TeachAssist"
        Height="800"
        Width="1200"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:TitleBar x:Name="AppTitleBar" Grid.ColumnSpan="2" Title="TeachAssist"/>

        <!-- Custom sidebar with gradient background -->
        <Border x:Name="Sidebar" Grid.Column="0" Width="220" Margin="0,32,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1E1B4B" Offset="0"/>
                    <GradientStop Color="#312E81" Offset="0.4"/>
                    <GradientStop Color="#3730A3" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo + brand -->
                <StackPanel Grid.Row="0" Margin="20,24,20,0" Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="10" ClipToBounds="True" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#818CF8" BlurRadius="12" ShadowDepth="0" Opacity="0.4" Direction="0"/>
                        </Border.Effect>
                        <Image Source="/logo.png" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="TeachAssist" FontSize="15" FontWeight="Bold"
                               Foreground="#E0E7FF" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Quick stat card in sidebar -->
                <Border Grid.Row="1" Margin="16,16,16,0" CornerRadius="10" Padding="16,12"
                        Background="#FFFFFF" Opacity="0.08">
                    <StackPanel>
                        <TextBlock Text="AVERAGE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#A5B4FC" Opacity="0.7"/>
                        <TextBlock x:Name="SidebarAverage" Text="--"
                                   FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                        <TextBlock x:Name="SidebarGpa" Text=""
                                   FontSize="11" Foreground="#C7D2FE" Opacity="0.6" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <StackPanel Grid.Row="3" Margin="10,0">
                    <TextBlock Text="MENU" FontSize="10" FontWeight="SemiBold"
                               Foreground="#818CF8" Opacity="0.5" Margin="10,0,0,10"/>

                    <!-- Dashboard -->
                    <Border x:Name="NavDashboard" CornerRadius="8" Padding="10,10" Margin="0,0,0,4"
                            Background="Transparent" Cursor="Hand"
                            MouseLeftButtonDown="NavItem_PreviewMouseLeftButtonDown"
                            Tag="Dashboard" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        To="1.02" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        To="1.02" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        To="1.0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        To="1.0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Home24" FontSize="16" Margin="0,0,10,0"
                                           Foreground="#C7D2FE"/>
                            <TextBlock Text="Dashboard" FontSize="13"
                                       Foreground="#E0E7FF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Settings -->
                    <Border x:Name="NavSettings" CornerRadius="8" Padding="10,10" Margin="0,0,0,4"
                            Background="Transparent" Cursor="Hand"
                            MouseLeftButtonDown="NavItem_PreviewMouseLeftButtonDown"
                            Tag="Settings" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        To="1.02" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        To="1.02" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        To="1.0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        To="1.0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="16" Margin="0,0,10,0"
                                           Foreground="#C7D2FE"/>
                            <TextBlock Text="Settings" FontSize="13"
                                       Foreground="#E0E7FF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="4" Margin="20,0,20,16">
                    <Border Height="1" CornerRadius="1" Margin="0,0,0,10"
                            Background="#FFFFFF" Opacity="0.08"/>
                    <TextBlock Text="TeachAssist Desktop" FontSize="10"
                               Foreground="#818CF8" Opacity="0.5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content area -->
        <Frame x:Name="ContentArea" Grid.Column="1" Margin="0,32,0,0"
               NavigationUIVisibility="Hidden"
               Navigated="ContentArea_Navigated"/>

        <!-- Toast notification overlay -->
        <StackPanel x:Name="ToastHost" Grid.Column="1"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,44,16,0"
                    Orientation="Vertical"/>
    </Grid>
</ui:FluentWindow>
